if __name__ == "__main__":
    detector = KeystrokeDynamicsDetector()
    
    print("Step 1: Profile Training Phase...")
    detector.train_baseline(authorized_profile)
    
    print("\nStep 2: Simulating Authorized User Session...")
    result_auth = detector.verify_session(authorized_profile)
    print(result_auth)
    
    print("\nStep 3: Simulating Attacker/Anomaly Session...")
