import numpy as np
import pandas as pd
from sklearn.ensemble import IsolationForest
import json

class KeystrokeDynamicsDetector:
    def __init__(self):
        # Using Isolation Forest for anomaly detection (unsupervised behavioral baseline)
        self.model = IsolationForest(contamination=0.1, random_state=42)
        
    def train_baseline(self, baseline_data):
        """Trains the model on the authorized user's typical typing metrics."""
        df = pd.DataFrame(baseline_data)
        # Features: Dwell Time (key press duration), Flight Time (time between keys)
        features = df[['dwell_time', 'flight_time']]
        self.model.fit(features)
        print("✅ Behavioral baseline established successfully.")

    def verify_session(self, current_session_data):
        """Verifies if the current typing behavior matches the baseline."""
        df = pd.DataFrame(current_session_data)
        features = df[['dwell_time', 'flight_time']]
        predictions = self.model.predict(features)
        
        # Calculate anomaly rate (-1 indicates an anomaly)
        anomaly_rate = np.mean(predictions == -1)
        
        print(f"🔍 Analysis Complete. Anomaly Rate: {anomaly_rate:.2%}")
        if anomaly_rate > 0.35: # Threshold for flag
            return "🚨 ALERT: Behavioral mismatch detected. Potential session hijacking!"
        return "🔒 ACCESS GRANTED: Behavioral biometrics verified."

# Mock Data: Simulation of keypress timing (in milliseconds)
authorized_profile = [
    {"dwell_time": 85, "flight_time": 120},
    {"dwell_time": 90, "flight_time": 115},
    {"dwell_time": 88, "flight_time": 130},
    {"dwell_time": 95, "flight_time": 110},
